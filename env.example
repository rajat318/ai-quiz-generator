import React, { useState, useEffect, useCallback } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { motion, AnimatePresence } from 'motion/react';
import { 
  ArrowLeft, ArrowRight, Bookmark, Clock, 
  ChevronRight, Flag, HelpCircle, CheckCircle2, 
  AlertCircle, Info, SendHorizontal
} from 'lucide-react';
import toast from 'react-hot-toast';
import { useLocalStorage } from '../hooks/useLocalStorage';
import { QuizSession, Question } from '../types';

export function QuizPlayer() {
  const { quizId } = useParams();
  const navigate = useNavigate();
  const [sessions, setSessions] = useLocalStorage<QuizSession[]>('edu_quiz_sessions', []);
  
  const [session, setSession] = useState<QuizSession | null>(null);
  const [currentIdx, setCurrentIdx] = useState(0);
  const [timeLeft, setTimeLeft] = useState(0);
  const [answers, setAnswers] = useState<Record<string, string>>({});
  const [bookmarks, setBookmarks] = useState<string[]>([]);
  const [isSubmitting, setIsSubmitting] = useState(false);

  useEffect(() => {
    const s = sessions.find(q => q.id === quizId);
    if (!s) {
      toast.error('Quiz not found');
      navigate('/generate');
      return;
    }
    setSession(s);
    setAnswers(s.answers || {});
    setTimeLeft(s.config.timeLimit * 60);
  }, [quizId, sessions, navigate]);

  const finishQuiz = useCallback(async () => {
    if (!session || isSubmitting) return;
    setIsSubmitting(true);
    
    // Calculate Score
    let correct = 0;
    session.questions.forEach(q => {
      if (answers[q.id] === q.correctAnswer) correct++;
    });

    const updatedSession: QuizSession = {
      ...session,
      answers,
      bookmarks,
      endTime: Date.now(),
      score: Math.round((correct / session.questions.length) * 100)
    };

    const updatedSessions = sessions.map(s => s.id === quizId ? updatedSession : s);
    setSessions(updatedSessions);
    
    toast.success('Quiz submitted successfully!');
    navigate(`/results/${quizId}`);
  }, [session, answers, bookmarks, sessions, quizId, navigate, setSessions, isSubmitting]);

  useEffect(() => {
    if (timeLeft <= 0 && session) {
      toast.error("Time's up! Automaticaly submitting...");
      finishQuiz();
      return;
    }

    const timer = setInterval(() => {
      setTimeLeft(prev => prev - 1);
    }, 1000);

    return () => clearInterval(timer);
  }, [timeLeft, session, finishQuiz]);

  if (!session) return null;

  const currentQuestion = session.questions[currentIdx];
  const progress = ((currentIdx + 1) / session.questions.length) * 100;

  const formatTime = (seconds: number) => {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, '0')}`;
  };

  const handleAnswerChange = (qId: string, answer: string) => {
    setAnswers(prev => ({ ...prev, [qId]: answer }));
  };

  const toggleBookmark = (qId: string) => {
    setBookmarks(prev => 
      prev.includes(qId) ? prev.filter(id => id !== qId) : [...prev, qId]
    );
  };

  return (
    <div className="flex-1 flex flex-col h-full bg-slate-950/50">
      {/* Quiz Header */}
      <div className="sticky top-0 z-40 glass border-b border-white/5 py-4">
        <div className="max-w-6xl mx-auto px-4 flex items-center justify-between">
          <div className="flex items-center gap-4">
             <button 
               onClick={() => navigate('/generate')}
               className="p-2 hover:bg-white/5 rounded-lg transition-all"
             >
               <ArrowLeft size={20} />
             </button>
             <div>
               <h2 className="font-bold text-slate-200">{session.config.topic}</h2>
               <p className="text-[10px] text-slate-500 uppercase tracking-widest">{session.config.subject} • {session.questions.length} Questions</p>
             </div>
          </div>

          <div className="flex items-center gap-6">
            <div className={`flex items-center gap-2 px-4 py-2 rounded-xl transition-all ${
              timeLeft < 60 ? 'bg-red-500/10 text-red-500 animate-pulse' : 'bg-cyan-500/10 text-cyan-400'
            }`}>
              <Clock size={16} />
              <span className="font-mono font-bold">{formatTime(timeLeft)}</span>
            </div>
            
            <button
              onClick={finishQuiz}
              className="px-6 py-2 bg-gradient-to-r from-cyan-500 to-indigo-600 rounded-xl font-bold text-xs flex items-center gap-2 hover:opacity-90 transition-all shadow-lg shadow-cyan-500/20"
            >
              Submit Quiz
              <SendHorizontal size={14} />
            </button>
          </div>
        </div>
        
        {/* Progress Bar */}
        <div className="absolute bottom-0 left-0 w-full h-1 bg-white/5 overflow-hidden">
          <motion.div 
            initial={{ width: 0 }}
            animate={{ width: `${progress}%` }}
            className="h-full bg-cyan-500 shadow-[0_0_10px_rgba(6,182,212,0.5)]"
          />
        </div>
      </div>

      <div className="flex-1 max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-4 gap-8 p-6">
        {/* Main Quest Area */}
        <div className="md:col-span-3 space-y-6">
          <AnimatePresence mode="wait">
            <motion.div
              key={currentIdx}
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -20 }}
              className="glass-card min-h-[400px] flex flex-col"
            >
              <div className="flex items-start justify-between mb-8">
                <div className="flex items-center gap-3">
                   <span className="w-10 h-10 rounded-full glass border-cyan-500/30 flex items-center justify-center font-bold text-cyan-400">
                     {currentIdx + 1}
                   </span>
                   <span className="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/5 text-slate-500">
                     {currentQuestion.difficulty}
                   </span>
                </div>
                <button 
                  onClick={() => toggleBookmark(currentQuestion.id)}
                  className={`p-3 rounded-xl transition-all ${
                    bookmarks.includes(currentQuestion.id) ? 'bg-amber-500/20 text-amber-500' : 'hover:bg-white/5 text-slate-500'
                  }`}
                >
                  <Bookmark size={20} fill={bookmarks.includes(currentQuestion.id) ? "currentColor" : "none"} />
                </button>
              </div>

              <h3 className="text-xl md:text-2xl font-medium leading-relaxed text-slate-100 mb-10">
                {currentQuestion.question}
              </h3>

              {/* Options */}
              <div className="space-y-4 flex-1">
                {currentQuestion.type === 'MCQ' || currentQuestion.type === 'True/False' ? (
                  currentQuestion.options?.map((option, idx) => (
                    <button
                      key={idx}
                      onClick={() => handleAnswerChange(currentQuestion.id, option)}
                      className={`w-full text-left p-4 rounded-2xl border transition-all flex items-center gap-4 group ${
                        answers[currentQuestion.id] === option
                          ? 'bg-cyan-500/20 border-cyan-500 text-cyan-100'
                          : 'bg-white/5 border-white/5 hover:bg-white/10 text-slate-400'
                      }`}
                    >
                      <div className={`w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs border ${
                        answers[currentQuestion.id] === option
                          ? 'bg-cyan-500 border-cyan-500 text-white'
                          : 'border-white/10 bg-white/5 text-slate-500'
                      }`}>
                        {String.fromCharCode(65 + idx)}
                      </div>
                      <span className="font-medium">{option}</span>
                    </button>
                  ))
                ) : (
                  <div className="space-y-4">
                    <p className="text-xs font-bold text-slate-500 uppercase flex items-center gap-2">
                       <Info size={14} /> 
                       {currentQuestion.type} type questions require brief typing or mental check.
                    </p>
                    <textarea 
                      className="input-field min-h-[150px]"
                      placeholder="Type your answer here..."
                      value={answers[currentQuestion.id] || ''}
                      onChange={(e) => handleAnswerChange(currentQuestion.id, e.target.value)}
                    />
                  </div>
                )}
              </div>

              {/* Navigation */}
              <div className="flex items-center justify-between pt-10 mt-10 border-t border-white/5">
                <button
                  disabled={currentIdx === 0}
                  onClick={() => setCurrentIdx(prev => prev - 1)}
                  className="px-6 py-2.5 glass-button border-white/10 disabled:opacity-30"
                >
                  <ArrowLeft size={18} />
                  Previous
                </button>
                
                {currentIdx < session.questions.length - 1 ? (
                  <button
                    onClick={() => setCurrentIdx(prev => prev + 1)}
                    className="px-8 py-2.5 bg-cyan-500 rounded-xl font-bold text-white flex items-center gap-2 shadow-lg shadow-cyan-500/20 active:scale-95 transition-all"
                  >
                    Next Question
                    <ArrowRight size={18} />
                  </button>
                ) : (
                  <button
                    onClick={finishQuiz}
                    className="px-8 py-2.5 bg-emerald-500 rounded-xl font-bold text-white flex items-center gap-2 shadow-lg shadow-emerald-500/20 active:scale-95 transition-all"
                  >
                    Submit Quiz
                    <SendHorizontal size={18} />
                  </button>
                )}
              </div>
            </motion.div>
          </AnimatePresence>
        </div>

        {/* Quest Navigation Sidebar */}
        <div className="hidden md:block space-y-6">
           <div className="glass-card p-4 space-y-4">
             <h4 className="text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Question Grid</h4>
             <div className="grid grid-cols-4 gap-2">
               {session.questions.map((q, idx) => (
                 <button
                   key={idx}
                   onClick={() => setCurrentIdx(idx)}
                   className={`w-10 h-10 rounded-lg text-xs font-bold flex items-center justify-center transition-all border ${
                     currentIdx === idx
                       ? 'bg-cyan-500 border-cyan-500 text-white ring-2 ring-cyan-500/30'
                       : bookmarks.includes(q.id)
                       ? 'bg-amber-500/20 border-amber-500/30 text-amber-500'
                       : answers[q.id]
                       ? 'bg-emerald-500/20 border-emerald-500/30 text-emerald-500'
                       : 'bg-white/5 border-white/5 text-slate-500 hover:border-white/20'
                   }`}
                 >
                   {idx + 1}
                 </button>
               ))}
             </div>

             <div className="pt-4 mt-4 border-t border-white/5 space-y-2">
               <div className="flex items-center gap-2 text-[10px] text-slate-500 uppercase font-bold tracking-widest">
                 <div className="w-2.5 h-2.5 rounded bg-emerald-500" />
                 Answered
               </div>
               <div className="flex items-center gap-2 text-[10px] text-slate-500 uppercase font-bold tracking-widest">
                 <div className="w-2.5 h-2.5 rounded bg-amber-500" />
                 Bookmarked
               </div>
               <div className="flex items-center gap-2 text-[10px] text-slate-500 uppercase font-bold tracking-widest">
                 <div className="w-2.5 h-2.5 rounded bg-white/10" />
                 Not Answered
               </div>
             </div>
           </div>

           <div className="glass-card p-4">
             <h4 className="text-xs font-bold uppercase tracking-widest text-slate-500 mb-3 flex items-center gap-2">
               <AlertCircle size={14} />
               Study Legend
             </h4>
             <ul className="space-y-3 text-[11px] text-slate-400">
               <li>• <b>MCQs</b> focus on memory & facts.</li>
               <li>• <b>Short Answer</b> builds concepts.</li>
               <li>• <b>HOTS</b> questions test logic.</li>
             </ul>
           </div>
        </div>
      </div>
    </div>
  );
}
