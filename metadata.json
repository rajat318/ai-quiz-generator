import React, { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  MessageSquareCode, Send, Sparkles, User, 
  Brain, Zap, BookOpen, Lightbulb, CornerDownLeft,
  RefreshCcw, Copy, Loader2
} from 'lucide-react';
import toast from 'react-hot-toast';
import { askStudyAssistant } from '../lib/gemini';

interface Message {
  id: string;
  role: 'user' | 'assistant';
  content: string;
  timestamp: number;
}

export function Assistant() {
  const [messages, setMessages] = useState<Message[]>([
    {
      id: 'init',
      role: 'assistant',
      content: "Hello! I'm your EduQuiz AI tutor. How can I help you excel in your studies today? You can ask me to explain concepts, create mnemonics, or summarize complex topics.",
      timestamp: Date.now()
    }
  ]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [messages]);

  const handleSend = async (e?: React.FormEvent) => {
    e?.preventDefault();
    if (!input.trim() || loading) return;

    const userMsg: Message = {
      id: Date.now().toString(),
      role: 'user',
      content: input,
      timestamp: Date.now()
    };

    setMessages(prev => [...prev, userMsg]);
    setInput('');
    setLoading(true);

    try {
      const response = await askStudyAssistant(input);
      const aiMsg: Message = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: response,
        timestamp: Date.now()
      };
      setMessages(prev => [...prev, aiMsg]);
    } catch (error) {
      toast.error('AI tutor is currently unavailable. Please try again later.');
    } finally {
      setLoading(false);
    }
  };

  const clearChat = () => {
    if (messages.length > 1) {
      setMessages([messages[0]]);
      toast.success('Chat cleared');
    }
  };

  const suggestions = [
    { label: 'Create a Mnemonic', prompt: 'Create a mnemonic for order of planets.' },
    { label: 'Explain like I\'m 5', prompt: 'Explain Quantum Entanglement simply.' },
    { label: 'Exam Tips', prompt: 'Give me 5 tips to manage time during an exam.' },
    { label: 'Quick Summary', prompt: 'Summarize causes of World War 1.' },
  ];

  return (
    <div className="flex-1 flex flex-col max-w-5xl mx-auto w-full px-4 h-full py-6">
      <div className="flex items-center justify-between mb-4">
        <div>
          <h1 className="text-2xl font-display font-extrabold flex items-center gap-3">
             <MessageSquareCode className="text-cyan-400" size={24} />
             Study Assistant
          </h1>
          <p className="text-slate-500 text-xs">Ask anything - I'm here to help you understand better.</p>
        </div>
        <button 
          onClick={clearChat}
          className="p-2 hover:bg-white/5 rounded-lg text-slate-500 transition-all"
        >
          <RefreshCcw size={16} />
        </button>
      </div>

      <div className="flex-1 glass rounded-2xl overflow-hidden flex flex-col relative min-h-0">
        {/* Messages */}
        <div 
          ref={scrollRef}
          className="flex-1 overflow-y-auto p-6 space-y-6 scroll-smooth custom-scrollbar"
        >
          {messages.map((msg) => (
            <motion.div
              key={msg.id}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              className={`flex items-start gap-4 ${msg.role === 'assistant' ? 'max-w-[85%]' : 'max-w-[85%] ml-auto flex-row-reverse'}`}
            >
              <div className={`w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 border ${
                msg.role === 'assistant' 
                  ? 'bg-cyan-500/10 border-cyan-500/20 text-cyan-400' 
                  : 'bg-indigo-500/10 border-indigo-500/20 text-indigo-400'
              }`}>
                {msg.role === 'assistant' ? <Sparkles size={20} /> : <User size={20} />}
              </div>
              <div className={`p-4 rounded-3xl ${
                msg.role === 'assistant' 
                  ? 'bg-white/5 border border-white/5 rounded-tl-none text-slate-200' 
                  : 'bg-indigo-600 rounded-tr-none text-white'
              }`}>
                <div className="prose prose-invert prose-sm max-w-none whitespace-pre-wrap leading-relaxed">
                  {msg.content}
                </div>
                <p className="mt-2 text-[10px] opacity-40 text-right">
                  {new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                </p>
              </div>
            </motion.div>
          ))}
          {loading && (
            <div className="flex items-start gap-4 max-w-[80%] animate-pulse">
               <div className="w-10 h-10 rounded-2xl glass flex items-center justify-center border-white/10 text-cyan-400">
                <Loader2 size={20} className="animate-spin" />
              </div>
              <div className="p-4 rounded-3xl glass border border-white/5 rounded-tl-none">
                <div className="flex gap-1.5 py-4">
                  <div className="w-2 h-2 rounded-full bg-cyan-400/50 animate-bounce" style={{ animationDelay: '0ms' }} />
                  <div className="w-2 h-2 rounded-full bg-cyan-400/50 animate-bounce" style={{ animationDelay: '150ms' }} />
                  <div className="w-2 h-2 rounded-full bg-cyan-400/50 animate-bounce" style={{ animationDelay: '300ms' }} />
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Floating Suggestions */}
        <div className="px-6 py-4 border-t border-white/5 bg-slate-950/20">
          <div className="flex flex-wrap gap-2">
            {suggestions.map((s, i) => (
              <button
                key={i}
                onClick={() => setInput(s.prompt)}
                className="px-3 py-1.5 rounded-full glass border-white/10 text-[11px] font-medium text-slate-400 hover:text-cyan-400 hover:border-cyan-500/30 transition-all flex items-center gap-1.5"
              >
                <Lightbulb size={12} className="text-amber-400" />
                {s.label}
              </button>
            ))}
          </div>
        </div>

        {/* Input area */}
        <div className="p-4 bg-slate-950/40 border-t border-white/5">
          <form 
            onSubmit={handleSend}
            className="relative flex items-center gap-2"
          >
            <input 
              type="text"
              placeholder="Ask me to explain anything..."
              className="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 pr-24 transition-all"
              value={input}
              onChange={(e) => setInput(e.target.value)}
              disabled={loading}
            />
            <div className="absolute right-2 flex items-center gap-2">
               <div className="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white/5 border border-white/10 text-[10px] font-bold text-slate-500">
                  <CornerDownLeft size={10} />
                  ENTER
               </div>
               <button
                 type="submit"
                 disabled={!input.trim() || loading}
                 className="p-3 bg-cyan-500 rounded-xl text-white hover:bg-cyan-600 disabled:opacity-50 disabled:cursor-not-allowed shadow-lg shadow-cyan-500/20 transition-all"
               >
                 <Send size={18} />
               </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}
